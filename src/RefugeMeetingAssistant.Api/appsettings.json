{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=RefugeMeetingAssistant;User Id=sa;Password=${DB_PASSWORD};TrustServerCertificate=true"
  },
  "Auth": {
    "UseDev": true,
    "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
    "Audience": "api://refuge-meeting-assistant"
  },
  "AWS": {
    "Region": "us-east-1",
    "SQS": {
      "ServiceUrl": "http://localhost:4566",
      "BotCommandsQueueUrl": "http://localhost:4566/000000000000/refuge-meeting-bot-commands",
      "ProcessingQueueUrl": "http://localhost:4566/000000000000/refuge-meeting-processing"
    }
  },
  "LMA": {
    "UseMock": true,
    "AppSyncUrl": "",
    "CognitoUserPoolId": "",
    "CognitoClientId": "",
    "KinesisStreamName": "",
    "Note": "Set LMA:UseMock=false and fill in AppSync/Cognito/Kinesis values after deploying LMA CloudFormation stack. Values are in CloudFormation Outputs."
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  }
}
