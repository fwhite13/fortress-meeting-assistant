{
  "name": "refuge-meeting-vpbot",
  "version": "1.0.0",
  "description": "Refuge Meeting Assistant — VP Bot Worker (SQS consumer + Playwright meeting bot)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.525.0",
    "@aws-sdk/client-s3": "^3.525.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "playwright": "^1.50.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
